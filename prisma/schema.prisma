generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id         String     @id @db.Uuid // Supabase auth.users ID
  email      String     @unique
  fullName   String?    @map("full_name")
  phone      String?
  address    String?
  pincode    String?
  role       String     @default("customer")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")
  orders     Order[]

  @@map("profiles")
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  sku         String   @unique
  category    String   // 'Racquets', 'Accessories', 'Apparel'
  stockCount  Int      @default(0) @map("stock_count")
  price       Decimal  @db.Decimal(10, 2)
  images      String[] // Array of image URLs
  description String?
  colorVariants ProductColorVariant[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("products")
}

enum OrderStatus {
  Pending
  Pickup_Pending
  Manual_Fulfillment_Required
  In_Workshop
  Repairing
  Ready_to_Return
  Shipped
  Completed
  Cancelled
}

model Order {
  id                String       @id @default(uuid()) @db.Uuid
  customerId        String?      @map("customer_id") @db.Uuid
  customer          Profile?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  serviceType       String?      @map("service_type")
  customerName      String?      @map("customer_name")
  customerEmail     String?      @map("customer_email")
  customerPhone     String?      @map("customer_phone")
  addressLine1      String?      @map("address_line1")
  city              String?
  state             String?
  pincode           String?
  status            OrderStatus  @default(Pending)
  paymentStatus     String       @default("pending") @map("payment_status")
  razorpayOrderId   String?      @map("razorpay_order_id")
  razorpayPaymentId String?      @map("razorpay_payment_id")
  razorpaySignature String?      @map("razorpay_signature")
  reversePickupBookedAt DateTime? @map("reverse_pickup_booked_at")
  logisticsDeposit  Decimal?     @map("logistics_deposit") @db.Decimal(10, 2)
  finalQuote        Decimal?     @map("final_quote") @db.Decimal(10, 2)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @default(now()) @updatedAt @map("updated_at")
  
  orderItems        OrderItem[]
  shipments         Shipment[]

  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Can refer to a physical product
  productId       String?  @map("product_id") @db.Uuid
  quantity        Int      @default(1)
  priceAtPurchase Decimal  @map("price_at_purchase") @db.Decimal(10, 2)
  color           String?  // Optional selected color variant
  
  // Or it can be a service
  serviceType     String?  @map("service_type") // 'stringing', 'repair'
  racquetBrand    String?  @map("racquet_brand")
  racquetModel    String?  @map("racquet_model")
  tensionLbs      Int?     @map("tension_lbs")
  stringName      String?  @map("string_name") // Selected string type (e.g. BG 65, BG80 Power)
  comments        String?  // Customer's notes/special instructions for this item
  repairImageUrl  String?  @map("repair_image_url") // Uploaded broken racquet photo

  @@map("order_items")
}

model Shipment {
  id                  String   @id @default(uuid()) @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shiprocketOrderId    String?  @map("shiprocket_order_id")
  awbCode             String?  @map("awb_code")
  shipmentStatus      String?  @map("shipment_status")
  isReverse           Boolean  @default(false) @map("is_reverse")
  provider            String   @default("shiprocket")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("shipments")
}

model ProductColorVariant {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName   String   @map("color_name")
  stockCount  Int      @default(0) @map("stock_count")
  imageUrl    String?  @map("image_url") // optional image URL specifically for this color
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("product_color_variants")
}

model Settings {
  id                  String   @id @default(uuid()) @db.Uuid
  repairPriceBelow4k  Decimal  @default(500.00) @db.Decimal(10, 2) @map("repair_price_below_4k")
  repairPriceAbove4k  Decimal  @default(700.00) @db.Decimal(10, 2) @map("repair_price_above_4k")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}

