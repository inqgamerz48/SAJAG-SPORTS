# --- Supabase Postgres (Prisma) ---
# For Vercel, DATABASE_URL should use the Supabase Connection Pooler URL (port 6543)
DATABASE_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[your-region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL should point directly to the database (port 5432) for running migrations
DIRECT_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[your-region].pooler.supabase.com:5432/postgres"

# --- Supabase Auth + Storage ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- NextAuth (Admin & User Authentication) ---
NEXTAUTH_SECRET=""
# In production, set NEXTAUTH_URL to your custom domain or Vercel URL (e.g., https://yourdomain.com)
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# --- Google OAuth (NextAuth + Supabase Google Login) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Razorpay (Payment Gateway) ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Shiprocket (Shipping Integration) ---
SHIPROCKET_API_TOKEN=""
SHIPROCKET_PICKUP_LOCATION_NAME=""
SHIPROCKET_PICKUP_NAME=""
SHIPROCKET_PICKUP_PHONE=""
SHIPROCKET_PICKUP_ADDRESS=""
SHIPROCKET_PICKUP_CITY=""
SHIPROCKET_PICKUP_STATE=""
SHIPROCKET_PICKUP_PINCODE=""
SHIPROCKET_SELLER_GST_TIN=""
SHIPROCKET_HSN_CODE=""
SHIPROCKET_CLIENT_NAME=""

# --- UploadThing (Media Uploads) ---
UPLOADTHING_TOKEN=""

# --- Email (SMTP Configuration - Optional) ---
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""

# --- Twilio SMS (Notifications - Optional) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Public app URL ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Store Settings (Fallback/defaults for shiprocket pickup details) ---
STORE_PHONE=""
STORE_ADDRESS=""
STORE_CITY=""
STORE_STATE=""
STORE_PINCODE=""

